BETTER_AUTH_SECRET=replace-with-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
# Use Neon pooled URL (*-pooler.*.neon.tech). Quote if query string contains &
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DB?sslmode=require"
# Auto-uses neon-http when URL contains neon.tech. Or set explicitly:
# DATABASE_DRIVER=neon-http
ADMIN_EMAIL=you@example.com

BETTER_AUTH_SECRET=replace-with-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000
# Neon pooled URL (recommended). App uses neon-http over HTTPS (port 443), not TCP 5432.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/DB?sslmode=require"
# Optional: DATABASE_DRIVER=postgres only for local Docker Postgres (not Neon)
# If Neon times out: wake project in Neon dashboard, check network, keep DATABASE_DRIVER unset
ADMIN_EMAIL=you@example.com

{
  "name": "js-ts-nerding",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "seed": "tsx src/db/seeds/seed.ts",
    "db:generate": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env --import tsx src/db/seeds/migrate.ts",
    "db:push": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --env-file=.env ./node_modules/drizzle-kit/bin.cjs studio",
    "db:promote-admin": "node --env-file=.env --import tsx src/db/seeds/promote-admin.ts",
    "db:sync-modules": "node --env-file=.env --import tsx src/db/seeds/sync-modules.ts",
    "clean": "rm -rf node_modules pnpm-lock.yaml && pnpm install --config.minimumReleaseAge=0"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/query-db-collection": "^0.0.3",
    "@tanstack/react-db": "^0.1.85",
    "@tanstack/react-form": "^1.32.1",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.167.0",
    "better-auth": "^1.6.11",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.511.0",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/router-devtools": "^1.167.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4"
  }
}

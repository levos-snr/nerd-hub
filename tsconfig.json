{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src",
    "server",
    "tests",
    "vite.config.ts",
    "eslint.config.js",
    "playwright.config.ts",
    "vitest.e2e.config.ts",
    "drizzle.config.ts"
  ]
}
